{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": [
      "@logseq/libs"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/*.test.ts"
  ]
}
